{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lubor-fedak/mtp-spec/schema/mtp-benchmark-result-v0.7.json",
  "title": "MTP Benchmark Result v0.7",
  "type": "object",
  "additionalProperties": false,
  "required": ["mtp_benchmark_version", "benchmark_result"],
  "properties": {
    "mtp_benchmark_version": {
      "type": "string",
      "const": "0.7"
    },
    "benchmark_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suite_id", "suite_name", "generated_at", "package_ref", "data_ref", "baseline_report_ref", "adapter_results", "summary"],
      "properties": {
        "suite_id": { "type": "string", "minLength": 1 },
        "suite_name": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "package_ref": { "type": "string", "minLength": 1 },
        "data_ref": { "type": "string", "minLength": 1 },
        "baseline_report_ref": { "type": "string", "minLength": 1 },
        "adapter_results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["adapter", "variant", "available", "executed", "passed_thresholds", "required", "thresholds"],
            "properties": {
              "adapter": { "type": "string" },
              "variant": { "type": "string" },
              "model": { "type": "string" },
              "available": { "type": "boolean" },
              "executed": { "type": "boolean" },
              "required": { "type": "boolean" },
              "skipped_reason": { "type": "string" },
              "report_ref": { "type": "string" },
              "report_valid": { "type": "boolean" },
              "overall_status": {
                "type": "string",
                "enum": ["success", "partial", "deviation", "failure", "skipped", "escalated"]
              },
              "self_drift": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "comparison_drift": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "state_agreement": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "difference_steps": {
                "type": "array",
                "items": { "type": "integer", "minimum": 1 }
              },
              "thresholds": {
                "type": "object",
                "additionalProperties": false,
                "required": ["min_comparison_drift", "min_state_agreement", "allowed_statuses"],
                "properties": {
                  "min_comparison_drift": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                  "min_state_agreement": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                  "allowed_statuses": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string" }
                  }
                }
              },
              "passed_thresholds": { "type": "boolean" }
            }
          }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total_adapters", "executed", "passed", "failed", "skipped", "suite_passed"],
          "properties": {
            "total_adapters": { "type": "integer", "minimum": 1 },
            "executed": { "type": "integer", "minimum": 0 },
            "passed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "skipped": { "type": "integer", "minimum": 0 },
            "suite_passed": { "type": "boolean" }
          }
        }
      }
    }
  }
}
