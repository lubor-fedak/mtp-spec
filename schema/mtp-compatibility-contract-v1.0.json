{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lubor-fedak/mtp-spec/schema/mtp-compatibility-contract-v1.0.json",
  "title": "MTP Compatibility Contract v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["mtp_compatibility_contract_version", "compatibility_contract"],
  "properties": {
    "mtp_compatibility_contract_version": {
      "type": "string",
      "const": "1.0"
    },
    "compatibility_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release", "normative_layers", "tooling", "compatibility", "evidence", "documentation"],
      "properties": {
        "release": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "status", "generated_at"],
          "properties": {
            "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
            "status": { "type": "string", "enum": ["production"] },
            "generated_at": { "type": "string", "format": "date-time" }
          }
        },
        "normative_layers": {
          "type": "object",
          "additionalProperties": false,
          "required": ["package_schema", "execution_report_schema", "registry_extension", "benchmark_artifacts", "release_artifacts", "key_provider_manifest"],
          "properties": {
            "package_schema": { "type": "string" },
            "execution_report_schema": { "type": "string" },
            "registry_extension": { "type": "string" },
            "benchmark_artifacts": { "type": "string" },
            "release_artifacts": { "type": "string" },
            "key_provider_manifest": { "type": "string" }
          }
        },
        "tooling": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 }
            }
          }
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["guarantees", "backward_compatibility", "deprecation_policy"],
          "properties": {
            "guarantees": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "backward_compatibility": {
              "type": "object",
              "additionalProperties": false,
              "required": ["accepts_package_versions", "emits_package_version", "accepts_execution_report_versions", "registry_signature_profiles"],
              "properties": {
                "accepts_package_versions": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                },
                "emits_package_version": { "type": "string" },
                "accepts_execution_report_versions": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                },
                "registry_signature_profiles": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                }
              }
            },
            "deprecation_policy": { "type": "string", "minLength": 1 }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["conformance_level", "provider_matrix_ref"],
          "properties": {
            "conformance_level": { "type": "string", "enum": ["l1", "l2", "l3", "all"] },
            "conformance_summary_hash": { "type": "string" },
            "conformance_summary_ref": { "type": "string" },
            "provider_matrix_ref": { "type": "string", "minLength": 1 }
          }
        },
        "documentation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["core_spec_ref", "registry_spec_ref", "architecture_ref"],
          "properties": {
            "core_spec_ref": { "type": "string", "minLength": 1 },
            "registry_spec_ref": { "type": "string", "minLength": 1 },
            "architecture_ref": { "type": "string", "minLength": 1 },
            "compatibility_spec_ref": { "type": "string" }
          }
        }
      }
    }
  }
}
