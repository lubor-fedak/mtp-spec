{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lubor-fedak/mtp-spec/schema/mtp-registry-entry-v0.6.json",
  "title": "MTP Registry Entry v0.6",
  "type": "object",
  "required": ["mtp_registry_version", "registry_entry"],
  "properties": {
    "mtp_registry_version": {
      "type": "string",
      "const": "0.6"
    },
    "registry_entry": {
      "type": "object",
      "required": [
        "entry_id",
        "artifact_type",
        "artifact_identity",
        "artifact_ref",
        "artifact_hash",
        "registry_status",
        "channel",
        "published_at",
        "signature_refs",
        "approval_refs",
        "trust"
      ],
      "properties": {
        "entry_id": {
          "type": "string",
          "format": "uuid"
        },
        "artifact_type": {
          "type": "string",
          "enum": ["package", "execution_report"]
        },
        "artifact_identity": {
          "$ref": "#/$defs/artifactIdentity"
        },
        "artifact_ref": {
          "type": "string",
          "minLength": 1
        },
        "artifact_hash": {
          "$ref": "#/$defs/hashRef"
        },
        "registry_status": {
          "type": "string",
          "enum": ["draft", "review", "approved", "deprecated"]
        },
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "signature_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "approval_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "conformance": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": ["l1", "l2", "l3"]
            },
            "summary_hash": {
              "type": "string",
              "pattern": "^sha256:[A-Fa-f0-9]{64}$"
            },
            "summary_ref": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "provenance": {
          "type": "object",
          "properties": {
            "source_repo": {
              "type": "string"
            },
            "source_commit": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "trust": {
          "type": "object",
          "required": ["signature_verified", "approval_required", "approved"],
          "properties": {
            "signature_verified": {
              "type": "boolean"
            },
            "approval_required": {
              "type": "boolean"
            },
            "approved": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "registry_status": {
                "const": "approved"
              }
            },
            "required": ["registry_status"]
          },
          "then": {
            "properties": {
              "approval_refs": {
                "minItems": 1
              },
              "trust": {
                "properties": {
                  "signature_verified": {
                    "const": true
                  },
                  "approval_required": {
                    "const": true
                  },
                  "approved": {
                    "const": true
                  }
                },
                "required": ["signature_verified", "approval_required", "approved"]
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "$defs": {
    "artifactIdentity": {
      "type": "object",
      "required": ["id", "version", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "hashRef": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "sha256"
        },
        "value": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
