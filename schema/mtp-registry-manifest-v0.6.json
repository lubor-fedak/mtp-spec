{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lubor-fedak/mtp-spec/schema/mtp-registry-manifest-v0.6.json",
  "title": "MTP Registry Manifest v0.6",
  "type": "object",
  "required": ["mtp_registry_version", "registry"],
  "properties": {
    "mtp_registry_version": {
      "type": "string",
      "const": "0.6"
    },
    "registry": {
      "type": "object",
      "required": [
        "id",
        "name",
        "created_at",
        "layout_version",
        "default_channel",
        "supported_channels"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "layout_version": {
          "type": "string",
          "const": "0.6"
        },
        "default_channel": {
          "type": "string",
          "minLength": 1
        },
        "supported_channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
