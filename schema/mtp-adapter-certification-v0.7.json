{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lubor-fedak/mtp-spec/schema/mtp-adapter-certification-v0.7.json",
  "title": "MTP Adapter Certification v0.7",
  "type": "object",
  "additionalProperties": false,
  "required": ["mtp_adapter_certification_version", "adapter_certification"],
  "properties": {
    "mtp_adapter_certification_version": {
      "type": "string",
      "const": "0.7"
    },
    "adapter_certification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter", "variant", "suite_id", "benchmark_result_ref", "status", "certified_at", "thresholds", "achieved"],
      "properties": {
        "adapter": { "type": "string", "minLength": 1 },
        "variant": { "type": "string", "minLength": 1 },
        "model": { "type": "string" },
        "suite_id": { "type": "string", "minLength": 1 },
        "benchmark_result_ref": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["certified", "not_certified", "skipped"]
        },
        "certified_at": { "type": "string", "format": "date-time" },
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min_comparison_drift", "min_state_agreement", "allowed_statuses"],
          "properties": {
            "min_comparison_drift": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "min_state_agreement": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "allowed_statuses": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        "achieved": {
          "type": "object",
          "additionalProperties": false,
          "required": ["available", "executed", "passed_thresholds"],
          "properties": {
            "available": { "type": "boolean" },
            "executed": { "type": "boolean" },
            "passed_thresholds": { "type": "boolean" },
            "overall_status": { "type": "string" },
            "comparison_drift": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "state_agreement": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          }
        }
      }
    }
  }
}
